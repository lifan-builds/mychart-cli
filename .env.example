# mychart-cli environment configuration
# Copy this file to .env and fill in your values.

# ── MyChart Settings ──────────────────────────────────────────────────────────
# Your MyChart portal URL.
AWESOME_MYCHART_URL=https://mychart.example.org/mychart

# Optional live-harness login automation. Keep real values only in local .env;
# never commit credentials.
AWESOME_MYCHART_USERNAME=
AWESOME_MYCHART_PASSWORD=
PROVIDENCE_MYCHART_USERNAME=
PROVIDENCE_MYCHART_PASSWORD=

# Optional tool overrides.
AWESOME_MYCHART_PYTHON=
AWESOME_MYCHART_SWIFT=/usr/bin/swift
